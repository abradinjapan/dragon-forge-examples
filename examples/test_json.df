[ test main ]
df.main()() = {
    [ run first test ]
    test.json.test_json_compiler()()
}

[ run test ]
test.json.test_json_compiler()() = {
    [ test compiler ]
    [ get file data ]
    df.set("./examples/data/test_json.json")(file_path)
    df.file_to_buffer(file_path)(file_text)

    [ print raw text ]
    df.print.buffer_as_string(file_text)()
    df.print.new_line()()

    [ compile ]
    df.json.compile(file_text, df.true)(workspace)
    df.print.new_line()()

    [ display message ]
    df.error.print_if_occured(workspace:error)()

    [ test traversal ]
    df.bits.xor(workspace:error:occured, df.constant.1)(no_error)
    @traverse no_error = {
        [ DEBUG ]
        df.set("Traversing by name!%0a;")(message)
        df.print.buffer_as_string(message)()

        [ test by name ]
        test.json.test_traversal.by_name(workspace, workspace:parslings)()
        df.print.new_line()()

        [ DEBUG ]
        df.set("Traversing by index!%0a;")(message)
        df.print.buffer_as_string(message)()

        [ test by index ]
        test.json.test_traversal.by_index(workspace, workspace:parslings)()
        df.print.new_line()()

        [ DEBUG ]
        df.set("Stringifying!%0a;")(message)
        df.print.buffer_as_string(message)()

        [ test stringifyer ]
        df.json.stringify.parslings(workspace !df.json.workspace)(string !df.buffer)
        df.print.buffer_as_string(string)()
        df.buffer.return(string)()
    }

    [ clean up file ]
    df.buffer.return(file_text)()

    [ clean up workspace ]
    df.json.compile.close.workspace(workspace)()
}

[ test json traversal by name ]
test.json.test_traversal.by_name(workspace !df.json.workspace, parslings !df.json.parslings)() = {
    [ setup strings ]
    df.set("foopo")(name_0)
    df.set("Hello")(name_1)

    [ test traversals ]
    df.json.traverse.retrieve_parsling.by_name(parslings:root, name_0)(parsling_0, found, not_found)
    df.json.traverse.retrieve_parsling.by_name(parsling_0, name_1)(parsling_1, found, not_found)

    [ DEBUG ]
    @failure not_found = {
        [ setup and print message ]
        df.set("Traversal Failure!%0a;")(message)
        df.print.buffer_as_string(message)()
    }

    [ print parsling value ]
    df.json.compile.print.parsling(workspace, parsling_1, df.constant.0)()
}

[ test json traversal by index ]
test.json.test_traversal.by_index(workspace !df.json.workspace, parslings !df.json.parslings)() = {
    [ test traversals ]
    df.json.traverse.retrieve_parsling.by_index(parslings:root, df.constant.0)(parsling_0, found, not_found)
    df.json.traverse.retrieve_parsling.by_index(parsling_0, df.constant.1)(parsling_1, found, not_found)

    [ DEBUG ]
    @failure not_found = {
        [ setup and print message ]
        df.set("Traversal Failure!%0a;")(message)
        df.print.buffer_as_string(message)()
    }

    [ print parsling value ]
    df.json.compile.print.parsling(workspace, parsling_1, df.constant.0)()
}
