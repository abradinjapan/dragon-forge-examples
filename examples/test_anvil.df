[ main ]
df.main()() = {
    test.anvil()()
}

[ run test ]
test.anvil()() = {
    [ setup workspace ]
    df.anvil.workspace.open()(workspace)

    [ do measuring pass ]
    df.anvil.workspace.setup_pass(workspace, df.false)(workspace)
    test.write_program(workspace)(workspace)

    [ do writing pass ]
    df.anvil.workspace.setup_pass(workspace, df.true)(workspace)
    test.write_program(workspace)(workspace)

    [ get program buffer ]
    df.copy(workspace:program)(program)

    [ install program into context ]
    df.context.open()(context)
    df.context.install_program(context, program)()

    [ run program ]
    df.set(df.integer.n1)(instruction_count)
    df.context.run(context, instruction_count)()

    [ clean up ]
    df.buffer.return(context)()
    df.buffer.return(program)()
}

[ generate program ]
test.write_program(workspace !df.anvil.workspace)(workspace !df.anvil.workspace) = {
    [ setup message string ]
    df.set("The dragon awakens!%0a;")(message)

    [ setup character cell ]
    df.set(df.integer.8192[ FIX LATER ])(write_to)

    [ generate character printers ]
    [ setup current ]
    df.pack(message, message:start)(current !df.current)

    [ character printing loop ]
    @write_prints df.always = {
        [ check if more characters to print, otherwise exit loop ]
        df.current.within_range(current)(in_range, out_of_range)
        df.jump.bottom(out_of_range, @write_prints)()

        [ get character ]
        df.address_to_cell(current:progress, df.constant.1)(character, current:progress)

        [ generate instructions ]
        df.anvil.write.instruction.write_cell(workspace, character, write_to)(workspace)
        df.anvil.write.instruction.debug.putchar(workspace, write_to)(workspace)

        [ jump to loop start ]
        df.jump.top(df.always, @write_prints)()
    }

    [ write program end ]
    df.anvil.write.instruction.stop(workspace)(workspace)
}
