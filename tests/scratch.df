df.main()() = {
    [ start timer ]
    df.time.now()(time.start)
    scratch.print.time(time.start)()

    [ declare variables ]
    df.set(df.integer.100)(a)
    df.set("Scratching...%0a;")(message)
    df.pack(a, a)(buff !df.buffer)

    [ print variables ]
    df.print.buffer_as_string(message)()
    df.print.integer.unsigned(a)()
    df.print.new_line()()
    df.print.integer.unsigned(buff:start)()
    df.print.new_line()()

    @oof

    @scope df.never = {
        df.set(df.integer.200)(b)
        df.print.integer.unsigned(b)()
        df.print.new_line()()

        @electric_boogaloo
    }

    scratch.say(message)(value)
    df.print.integer.unsigned(value)()
    df.print.new_line()()

    scratch.create.box_3D()(box)
    scratch.print.box_3D(box)()

    scratch.test.jumping()()
    df.set(df.integer.22)(c)
    scratch.test.checking(c)()

    [ test maths! ]
    scratch.test.maths(a, c)(math)
    scratch.test.maths.print(math)()

    df.copy(math)(more_maths)
    scratch.test.maths.print(more_maths)()
    df.pack.null()(no_maths !scratch.maths)
    scratch.test.maths.print(no_maths)()

    [ test buffers ]
    scratch.test.buffer()()

    [ test printing ]
    scratch.test.printing()()

    [ test file buffer movers ]
    scratch.test.file_buffer_movers()()

    [ test lists ]
    df.set("fluffy")(message)
    df.set(df.integer.9)(increase)
    scratch.test.list(increase, message)()

    [ test bits ]
    scratch.test.bits()()

    [ test buffer assorted ]
    scratch.test.buffers_assorted()()

    [ test structures assorted ]
    scratch.test.structures_assorted()()

    [ test current assorted ]
    scratch.test.current_assorted(message)()

    [ test compiler assorted ]
    scratch.test.compiler_assorted()()

    [ test allocation finder ]
    scratch.test.find_allocation()()

    [ test allocation limit ]
    scratch.test.allocation_limits()()

    [ test time functions ]
    scratch.test.time_assorted()()

    [ test stack functionality ]
    scratch.test.stack_assorted()()
    
    [ end timer ]
    df.time.now()(time.end)
    scratch.print.time(time.end)()

    [ print elapsed time ]
    df.integer.subtract(time.end:seconds, time.start:seconds)(seconds_elapsed)
    df.integer.subtract(time.end:nanoseconds, time.start:nanoseconds)(nanoseconds_elapsed)
    df.pack(seconds_elapsed, nanoseconds_elapsed)(time.taken !df.time)
    scratch.print.time(time.taken)()

    [ test stop ]
    df.set("Stopping!%0a;")(message)
    df.print.buffer_as_string(message)()

    [ stop ]
    [ df.execution.stop()() ]

    [ print failure ]
    df.set("Apparently not stopping!%0a;")(message)
    df.print.buffer_as_string(message)()
}

[ test current assorted ]
scratch.test.current_assorted(message !df.buffer)() = {
    [ setup current ]
    df.pack(message, message:start)(current !df.current)

    [ loop start ]
    @start

    [ check if in range ]
    df.current.within_range(current)(continue, exit)
    df.jump(exit, @exit)()

    [ print string ]
    df.pack(current:progress, current:buffer:end)(slice !df.buffer)
    df.print.buffer_as_string(slice)()
    df.print.new_line()()

    [ increment current ]
    df.integer.add(current:progress, df.constant.1)(current:progress)

    [ jump to start ]
    df.jump(df.always, @start)()

    [ loop exit ]
    @exit
}

[ test structure operations ]
scratch.test.structures_assorted()() = {
    [ print test header ]
    df.set("Structure Assorted Data:")(message)
    df.print.buffer_as_string(message)()
    df.print.new_line()()

    [ setup data ]
    df.pack(df.constant.0, df.constant.1)(a !df.buffer)
    df.pack.null()(b !df.list)

    [ calculate size ]
    df.structure.byte_size(a)(a.length)
    df.structure.byte_size(b)(b.length)

    [ print length ]
    df.print.integer.unsigned(a.length)()
    df.print.new_line()()
    df.print.integer.unsigned(b.length)()
    df.print.new_line()()

    [ open list ]
    df.set(df.integer.16)(increase)
    df.buffer.request(increase)(buffer)

    [ pack increment ]
    df.set("Pack Increment:%0a;")(message)
    df.print.buffer_as_string(message)()
    df.pack.increment(df.constant.5, df.constant.2)(output !scratch.box_3D)
    df.print.integer.unsigned(output:x)()
    df.print.new_line()()
    df.print.integer.unsigned(output:y)()
    df.print.new_line()()
    df.print.integer.unsigned(output:z)()
    df.print.new_line()()

    [ close buffer ]
    df.buffer.return(buffer)()
}

[ test buffer operations ]
scratch.test.buffers_assorted()() = {
    [ setup variables ]
    df.set("Buffer calculations:%0A;")(message)
    df.set(df.integer.10)(start)
    df.set(df.integer.20)(end)
    df.pack(start, end)(buffer !df.buffer)

    [ do calculations ]
    df.buffer.calculate.length(buffer)(result.length)
    df.buffer.calculate.end_address(start, result.length)(result.end)
    df.buffer.calculate.start_address(result.length, end)(result.start)

    [ print data ]
    df.print.buffer_as_string(message)()
    df.print.integer.unsigned(result.length)()
    df.print.new_line()()
    df.print.integer.unsigned(result.end)()
    df.print.new_line()()
    df.print.integer.unsigned(result.start)()
    df.print.new_line()()
}

[ test lists ]
scratch.test.list(increase !df.cell, data !df.buffer)() = {
    [ open list ]
    df.list.open(increase)(list)

    [ append data to list ]
    df.list.append.buffer_data(list, data)(list)
    df.list.append.buffer_data(list, data)(list)
    df.list.append.buffer_data(list, data)(list)

    [ print list ]
    scratch.print.list(list)()
    df.print.new_line()()
    scratch.print.list_as_string(list)()
    df.print.new_line()()

    [ close list ]
    df.list.close(list)()
}

[ print list as string ]
scratch.print.list_as_string(list !df.list)() = {
    [ create string buffer ]
    df.list.calculate.content_buffer(list)(string)

    [ print buffer ]
    df.print.buffer_as_string(string)()
}

[ print list raw data ]
scratch.print.list(list !df.list)() = {
    [ setup strings ]
    df.set("[ ")(header)
    df.set(", ")(separator)
    df.set(" ]")(footer)

    [ print list ]
    [ print allocation ]
    df.print.buffer_as_string(header)()
    df.print.integer.unsigned(list:allocation:start)()
    df.print.buffer_as_string(separator)()
    df.print.integer.unsigned(list:allocation:end)()

    [ print length ]
    df.print.buffer_as_string(separator)()
    df.print.integer.unsigned(list:length)()

    [ print increase ]
    df.print.buffer_as_string(separator)()
    df.print.integer.unsigned(list:increase)()

    [ print footer ]
    df.print.buffer_as_string(footer)()
}

[ test file mover ]
scratch.test.file_buffer_movers()() = {
    [ test file reader ]
    [ setup file paths ]
    df.set("./README.md")(readme_path)
    df.set("../dragon-testing/notes/oof.md")(destination_path)

    [ open the file ]
    df.file_to_buffer(readme_path)(buffer)

    [ print file ]
    df.print.buffer_as_string(buffer)()

    [ write to new file ]
    df.buffer_to_file(buffer, destination_path)()

    [ close file ]
    df.buffer.return(buffer)()

    [ delete the file ]
    df.delete_file(destination_path)()
}

[ test printing ]
scratch.test.printing()() = {
    [ setup data ]
    df.set("This is a string.")(string)
    df.set(df.integer.127)(cell)

    [ test prints ]
    df.print.buffer_as_string(string)()
    df.print.new_line()()
    df.print.binary.lower_to_higher(cell)()
    df.print.new_line()()

    [ test tab printing ]
    df.set(df.integer.2)(tab_count)
    df.print.tabs(tab_count)()
    df.print.buffer_as_string(string)()
    df.print.new_line()()
}

scratch.test.checking(checking_value !df.cell)() = {
    [ setup variables ]
    df.set(df.integer.11)(lower_end)
    df.set(df.integer.33)(higher_end)
    df.integer.within_range(lower_end, checking_value, higher_end)(should_run, shouldnt_run)

    [ skip print if necessary ]
    df.jump(shouldnt_run, @skip_print)()

    [ print ]
    df.set("Within range!%0A;")(message)
    df.print.buffer_as_string(message)()

    [ offset ]
    @skip_print
}

scratch.say(message !df.buffer)(w !df.cell) = {
    df.print.buffer_as_string(message)()
    df.set(df.integer.4321)(w)
}

scratch.create.box_3D()(output !scratch.box_3D) = {
    df.set(df.integer.333)(x)
    df.set(df.integer.444)(y)
    df.set(df.integer.555)(z)
    df.pack(x, y, z)(output !scratch.box_3D)
}

scratch.print.box_3D(box !scratch.box_3D)() = {
    df.set("Box: %0A;")(title)
    df.print.buffer_as_string(title)()
    df.set("%09;")(tab)
    df.print.buffer_as_string(tab)()
    df.print.integer.unsigned(box:x)()
    df.print.new_line()()
    df.print.buffer_as_string(tab)()
    df.print.integer.unsigned(box:y)()
    df.print.new_line()()
    df.print.buffer_as_string(tab)()
    df.print.integer.unsigned(box:z)()
    df.print.new_line()()
}

!scratch.box_3D(x !df.cell, y !df.cell, z !df.cell)

[ test normal jumping ]
scratch.test.jumping()() = {
    [ setup loop data ]
    df.set(df.integer.0)(bottom)
    df.set(df.integer.0)(current)
    df.set(df.integer.10)(top)
    df.set(df.integer.1)(increment)

    [ setup offset ]
    @start

    [ check for out of bounds ]
    df.integer.within_range(bottom, current, top)(shouldnt_quit, should_quit)
    df.jump(should_quit, @exit)()

    [ print variable ]
    df.print.integer.unsigned(current)()
    df.print.new_line()()

    [ increment variable ]
    df.integer.add(current, increment)(current)

    [ jump to loop start ]
    df.jump(df.always, @start)()

    [ end loop ]
    @exit
}

[ math conglomerate ]
!scratch.maths(addition !df.cell #df.json.boolean, subtraction !df.cell, multiplication !df.cell, division !df.cell, modulous !df.cell)

[ test math ]
scratch.test.maths(a !df.cell, b !df.cell)(maths !scratch.maths) = {
    [ do maths ]
    df.integer.add(a, b)(maths:addition)
    df.integer.subtract(a, b)(maths:subtraction)
    df.integer.multiply(a, b)(maths:multiplication)
    df.integer.divide(a, b)(maths:division)
    df.integer.modulous(a, b)(maths:modulous)
}

[ print maths ]
scratch.test.maths.print(maths !scratch.maths)() = {
    [ print header ]
    df.set("maths(")(title)
    df.set(" ")(space)
    df.print.buffer_as_string(title)()

    [ print values ]
    df.print.integer.unsigned(maths:addition)()
    df.print.buffer_as_string(space)()
    df.print.integer.unsigned(maths:subtraction)()
    df.print.buffer_as_string(space)()
    df.print.integer.unsigned(maths:multiplication)()
    df.print.buffer_as_string(space)()
    df.print.integer.unsigned(maths:division)()
    df.print.buffer_as_string(space)()
    df.print.integer.unsigned(maths:modulous)()

    [ print footer ]
    df.set(")%0A;")(footer)
    df.print.buffer_as_string(footer)()
}

[ test buffers ]
scratch.test.buffer()() = {
    [ allocate buffer ]
    df.set(df.integer.152)(size)
    df.buffer.request(size)(buffer)

    [ setup string & index data ]
    df.set("Hello World!%0A;")(message)
    df.set(df.integer.1)(byte_count)

    [ read character from string ]
    df.address_to_cell(message:start, byte_count)(data, advancement)

    [ increment data ]
    df.set(df.integer.1)(increment)
    df.integer.add(data, increment)(data)

    [ replace character in string ]
    df.cell_to_address(data, byte_count, message:start)(advancement)

    [ print new string ]
    df.print.buffer_as_string(message)()

    [ deallocate buffer ]
    df.buffer.return(buffer)()
}

[ test bits ]
scratch.test.bits()() = {
    [ setup variables ]
    df.set(df.binary.1010_0101)(a)
    df.set(df.binary.1010_1010)(b)
    df.set(df.integer.2)(c)

    [ test bits ]
    df.bits.or(a, b)(or_result)
    df.bits.invert(a)(invert_result)
    df.bits.and(a, b)(and_result)
    df.bits.xor(a, b)(xor_result)
    df.bits.shift_higher(a, c)(shift_higher_result)
    df.bits.shift_lower(a, c)(shift_lower_result)
    df.bits.overwrite(b[mask], a[old_bits], c[new_bits])(overwrite_result)

    [ print results ]
    df.print.binary.lower_to_higher(b)()
    df.print.new_line()()
    df.print.binary.lower_to_higher(or_result)()
    df.print.new_line()()
    df.print.binary.lower_to_higher(invert_result)()
    df.print.new_line()()
    df.print.binary.lower_to_higher(and_result)()
    df.print.new_line()()
    df.print.binary.lower_to_higher(xor_result)()
    df.print.new_line()()
    df.print.binary.lower_to_higher(shift_higher_result)()
    df.print.new_line()()
    df.print.binary.lower_to_higher(shift_lower_result)()
    df.print.new_line()()
    df.print.binary.lower_to_higher(overwrite_result)()
    df.print.new_line()()
}

[ print time ]
scratch.print.time(time !df.time)() = {
    df.set("Current time: [ seconds: ")(message)
    df.print.buffer_as_string(message)()
    df.print.integer.unsigned(time:seconds)()
    df.set(", nanoseconds: ")(message)
    df.print.buffer_as_string(message)()
    df.print.integer.unsigned(time:nanoseconds)()
    df.set(" ]%0A;")(message)
    df.print.buffer_as_string(message)()
}

[ test tags ]
!scratch.tags(
    buffer !df.buffer #df.json.buffer.addresses
)

[ test compiler assorted ]
scratch.test.compiler_assorted()() = {
    [ get source file ]
    df.set("../dragon-testing/demonstration/hello-world.dragon")(file_path)
    df.file_to_buffer(file_path)(source)

    [ print file ]
    df.print.buffer_as_string(source)()
    df.print.new_line()()

    [ append source file to source file list ]
    df.structure.byte_size(source)(increase)
    df.list.open(increase)(sources)
    df.list.append.buffer(sources, source)(sources)

    [ DEBUG TEST - give incorrect buffer size ]
    [ df.integer.add(sources:length, df.constant.1)(sources:length) ]

    [ DEBUG TEST - append null buffer ]
    [ df.pack.null()(null_buffer !df.buffer)
    df.list.append.buffer(sources, null_buffer)(sources) ]

    [ get buffer of buffers ]
    df.list.calculate.content_buffer(sources)(sources.buffer)

    [ create settings ]
    df.compiler.configure.default_compile()(settings)

    [ compile ]
    df.compiler.compile(sources.buffer, settings)(byte_code, debug_information, compiler.error)
    @print_compilation_error compiler.error:occured = {
        [ generate error ]
        df.error.generate(compiler.error:message, compiler.error:location)(compilation.error)

        [ print error ]
        df.error.print_if_occured(compilation.error)()

        [ skip context creation and program running ]
        df.jump(df.always, @clean_up)()
    }

    [ setup context ]
    df.context.open()(context)
    df.context.install_program(context, byte_code)()

    [ do stats for context ]
    df.buffer.calculate.length(context)(context.length)
    df.print.integer.unsigned(context.length)()
    df.print.new_line()()

    [ run code ]
    df.set(df.integer.n1)(instruction_count)
    df.context.run(context, instruction_count)()

    [ clean up context ]
    @clean_up_context
    df.buffer.return(context)()

    [ clean up ]
    @clean_up
    df.buffer.return(byte_code)()
    df.buffer.return(source)()
    df.list.close(sources)()
}

[ test allocation checker ]
scratch.test.find_allocation()() = {
    [ setup allocation ]
    df.buffer.request(df.constant.64)(real_allocation)

    [ setup searches ]
    df.copy(real_allocation)(search_1)
    df.copy(real_allocation)(search_2)
    df.copy(real_allocation)(search_3)

    [ test search 1 ]
    [ must check for exact same buffer ]
    df.find_allocation(search_1)(found, found_allocation)

    [ print findings ]
    scratch.test.find_allocation.print.result(found, found_allocation)()
    df.print.new_line()()

    [ test search 2 ]
    [ make test 2 beyond the bounds of the allocation ]
    df.integer.subtract(search_2:start, df.constant.1)(search_2:start)
    df.integer.add(search_2:end, df.constant.1)(search_2:end)

    [ test search ]
    df.find_allocation(search_2)(found, found_allocation)

    [ print findings ]
    scratch.test.find_allocation.print.result(found, found_allocation)()
    df.print.new_line()()

    [ test search 3 ]
    [ make test 3 within the bounds of the allocation ]
    df.integer.add(search_3:start, df.constant.1)(search_3:start)
    df.integer.subtract(search_3:end, df.constant.1)(search_3:end)

    [ test search ]
    df.find_allocation(search_3)(found, found_allocation)

    [ print findings ]
    scratch.test.find_allocation.print.result(found, found_allocation)()
    df.print.new_line()()

    [ clean up test allocation ]
    df.buffer.return(real_allocation)()
}

[ print result from allocation test ]
scratch.test.find_allocation.print.result(found !df.cell, source_allocation !df.buffer)() = {
    [ setup strings ]
    df.set("[ ")(header)
    df.set(", ")(separator)
    df.set(" ]")(footer)

    [ print result ]
    df.print.buffer_as_string(header)()
    df.print.integer.unsigned(found)()
    df.print.buffer_as_string(separator)()
    df.print.integer.unsigned(source_allocation:start)()
    df.print.buffer_as_string(separator)()
    df.print.integer.unsigned(source_allocation:end)()
    df.print.buffer_as_string(footer)()
}

[ check allocation limit ]
scratch.test.allocation_limits()() = {
    [ setup size ]
    df.set(df.hexadecimal.1000000000)(size)

    [ allocate ]
    df.buffer.request(size)(allocation)

    [ print allocation ]
    df.print.buffer(allocation)()
    df.print.new_line()()

    [ return allocation ]
    df.buffer.return(allocation)()

    [ yay! no crash! ]
    df.set("No crashes with the eternal dragon!%0a;")(message)
    df.print.buffer_as_string(message)()
}

[ test time functions ]
scratch.test.time_assorted()() = {
    [ setup constants ]
    df.set(df.integer.1_000_000_000)(nanoseconds_in_second)
    df.integer.subtract(nanoseconds_in_second, df.constant.1)(just_under)

    [ setup dummy times ]
    df.pack(df.constant.0, just_under)(a !df.time)
    df.pack(df.constant.0, df.constant.1)(b !df.time)

    [ print time ]
    scratch.print.time(a)()
    scratch.print.time(b)()

    [ add times ]
    df.time.add(a, b)(c)

    [ print result ]
    scratch.print.time(c)()

    [ print space ]
    df.print.new_line()()
}

[ test stack functions ]
scratch.test.stack_assorted()() = {
    [ print current stack ]
    df.print.current(df.call_stack)()
    df.print.new_line()()

    [ allocate new stack ]
    df.set(df.integer.100000)(length)
    df.buffer.request(length)(new_stack.buffer)
    df.pack(new_stack.buffer, new_stack.buffer:start)(new_stack !df.current)

    [ save old stack ]
    df.copy(df.call_stack)(old_stack)

    [ install new stack ]
    df.copy(new_stack)(df.call_stack)

    [ print stack ]
    df.print.current(df.call_stack)()
    df.print.new_line()()

    [ reinstall old stack ]
    df.copy(old_stack)(df.call_stack)

    [ clean up old stack ]
    df.buffer.return(new_stack.buffer)()
}
